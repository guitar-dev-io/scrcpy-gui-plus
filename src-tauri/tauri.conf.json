{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mobile Device Studio",
  "version": "1.0.0",
  "identifier": "com.guitar.scrcpy-gui-plus-v4",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mobile Device Studio",
        "width": 1200,
        "height": 890,
        "visible": false,
        "resizable": true,
        "center": true,
        "transparent": false,
        "decorations": true
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 500,
        "height": 400,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "center": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$PICTURE/**",
          "$DOWNLOAD/**",
          "$VIDEO/**",
          "$DESKTOP/**",
          "$DOCUMENT/**"
        ]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "dmg", "appimage", "deb"],
    "publisher": "KB-kil0bit",
    "copyright": "Copyright © 2026 KB-kil0bit",
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
